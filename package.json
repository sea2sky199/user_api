{
  "name": "chem-match-user-api",
  "version": "0.1.0",
  "description": "CHEM application api for storing authentication information",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "DEBUG=CHEM* nodemon --watch app.js --watch ./services/ --watch ./migrations/ --watch ./database/ --watch ./routes/ --watch ./models/ --watch ./controllers/ --watch package.json app.js",
    "bdd": "nyc --reporter=lcov --reporter=text-summary --exclude migrations --all node app.js",
    "test": "jest --runInBand --forceExit",
    "migrate": "knex migrate:latest --knexfile ./services/database/migrations/20190717123436_create-users-table.js"
  },
  "author": "real code",
  "license": "ISC",
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^1.19.1",
    "nyc": "^14.1.1",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "body-parser": "^1.19.0",
    "cfenv": "^1.2.4",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-basic-auth": "^1.2.0",
    "knex": "^0.19.5",
    "mysql2": "^1.6.5",
    "request": "^2.88.0",
    "swagger-jsdoc": "^3.3.0",
    "swagger-ui-express": "^4.0.7"
  }
}
